{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catholic-daily-app.local/schemas/readings-import.v1.schema.json",
  "title": "Readings bundle import (V1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "effective_from",
    "source_attribution",
    "days"
  ],
  "properties": {
    "bundle_version": {
      "type": "string",
      "minLength": 1,
      "description": "Semantic version or dated tag, e.g. 2026.1.0"
    },
    "conference_code": {
      "type": "string",
      "default": "KWI"
    },
    "effective_from": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO-8601 calendar date"
    },
    "source_attribution": {
      "type": "string",
      "minLength": 1
    },
    "content_license_tag": {
      "type": "string"
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["liturgical_date", "blocks"],
        "properties": {
          "liturgical_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "cycle_metadata": {
            "type": "object"
          },
          "blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sort_order", "kind", "body"],
              "properties": {
                "sort_order": { "type": "integer", "minimum": 0 },
                "kind": {
                  "type": "string",
                  "enum": ["FIRST", "PSALM", "SECOND", "GOSPEL"]
                },
                "reference": { "type": "string" },
                "title": { "type": "string" },
                "body": { "type": "string", "minLength": 1 },
                "source_line": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    }
  }
}

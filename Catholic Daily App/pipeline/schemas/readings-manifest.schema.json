{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catholic-daily-app.local/schemas/readings-manifest.schema.json",
  "title": "Static host manifest for optional remote readings bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["readings_bundle_version", "bundle_url", "sha256"],
  "properties": {
    "readings_bundle_version": { "type": "string", "minLength": 1 },
    "bundle_url": { "type": "string", "format": "uri" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "min_app_version": { "type": "string" }
  }
}

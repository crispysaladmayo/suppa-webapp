{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catholic-daily-app.local/schemas/editorial-piece.schema.json",
  "title": "Editorial (renungan) static JSON",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "liturgical_date",
    "body",
    "byline",
    "published_at"
  ],
  "properties": {
    "liturgical_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "title": { "type": "string" },
    "body": { "type": "string", "minLength": 1 },
    "byline": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "default": "id" },
    "ai_assisted": { "type": "boolean", "default": false },
    "human_reviewed": { "type": "boolean", "default": false },
    "published_at": { "type": "string", "minLength": 1 },
    "source_attribution": { "type": "string" },
    "external_id": { "type": "string" }
  }
}

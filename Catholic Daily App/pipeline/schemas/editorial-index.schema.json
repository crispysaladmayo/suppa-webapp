{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catholic-daily-app.local/schemas/editorial-index.schema.json",
  "title": "Editorial index for lazy-fetch per day",
  "type": "object",
  "additionalProperties": false,
  "required": ["updated_at", "pieces"],
  "properties": {
    "updated_at": { "type": "string", "minLength": 1 },
    "pieces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["liturgical_date", "url"],
        "properties": {
          "liturgical_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "url": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
